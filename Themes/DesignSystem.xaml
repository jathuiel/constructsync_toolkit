<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── BACKGROUNDS ─────────────────────────── -->
    <!-- Base: fundo principal de janelas -->
    <SolidColorBrush x:Key="Base"     Color="#FFFFFF"/>
    <!-- Mantle: fundo de listas e grades -->
    <SolidColorBrush x:Key="Mantle"   Color="#F5F5F5"/>
    <!-- Surface0: hover / cabeçalho de grade -->
    <SolidColorBrush x:Key="Surface0" Color="#E8E8E8"/>
    <!-- Surface1: bordas, botão ghost, seleção -->
    <SolidColorBrush x:Key="Surface1" Color="#D1D1D1"/>
    <!-- InputBg: fundo de campos de texto -->
    <SolidColorBrush x:Key="InputBg"  Color="#FAFAFA"/>

    <!-- ── TEXT ────────────────────────────────── -->
    <!-- Texto principal -->
    <SolidColorBrush x:Key="Text"     Color="#2E2E2E"/>
    <!-- Rótulos / labels -->
    <SolidColorBrush x:Key="Subtext0" Color="#5A5A5A"/>
    <!-- Textos secundários / status -->
    <SolidColorBrush x:Key="Overlay1" Color="#7A7A7A"/>
    <!-- Texto desabilitado -->
    <SolidColorBrush x:Key="TextDisabled" Color="#B0B0B0"/>

    <!-- ── ACCENT ──────────────────────────────── -->
    <!-- Ação primária -->
    <SolidColorBrush x:Key="Accent"        Color="#FC6A0A"/>
    <!-- Hover em ação primária -->
    <SolidColorBrush x:Key="AccentHover"   Color="#FF7A1F"/>
    <!-- Pressed em ação primária -->
    <SolidColorBrush x:Key="AccentPressed" Color="#E74504"/>

    <!-- ── SEMANTIC ────────────────────────────── -->
    <!-- Confirmação / sucesso -->
    <SolidColorBrush x:Key="Success"   Color="#2E7D32"/>
    <!-- Ações destrutivas / erro -->
    <SolidColorBrush x:Key="Destructive" Color="#D32F2F"/>
    <!-- Avisos -->
    <SolidColorBrush x:Key="Warning"   Color="#ED6C02"/>
    <!-- Informações -->
    <SolidColorBrush x:Key="Info"      Color="#0288D1"/>

    <!-- ── BORDERS ─────────────────────────────── -->
    <!-- Bordas padrão -->
    <SolidColorBrush x:Key="Border"      Color="#D1D1D1"/>
    <!-- Borda em foco -->
    <SolidColorBrush x:Key="BorderFocus" Color="#FC6A0A"/>

    <!-- ── CAMPO DE TEXTO ──────────────────────── -->
    <Style x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Background"      Value="{StaticResource InputBg}"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="CaretBrush"      Value="{StaticResource Text}"/>
        <Setter Property="SelectionBrush"  Value="{StaticResource Surface1}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <Grid Margin="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Tag}"
                                       Foreground="{StaticResource Overlay1}"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}"
                                                         Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{StaticResource BorderFocus}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── BOTÕES ──────────────────────────────── -->

    <!-- AccentButton — botão primário (laranja) -->
    <!-- Hover → AccentHover | Pressed → AccentPressed -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource Accent}"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="12,6"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentPressed}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GhostButton — botão secundário (cinza) -->
    <Style x:Key="GhostButton" TargetType="Button"
           BasedOn="{StaticResource AccentButton}">
        <Setter Property="Background" Value="{StaticResource Surface1}"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
    </Style>

    <!-- NavButton — botões compactos de navegação -->
    <Style x:Key="NavButton" TargetType="Button"
           BasedOn="{StaticResource GhostButton}">
        <Setter Property="Padding"  Value="8,3"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="MinWidth" Value="28"/>
    </Style>

    <!-- GreenButton — ação de confirmação -->
    <Style x:Key="GreenButton" TargetType="Button"
           BasedOn="{StaticResource AccentButton}">
        <Setter Property="Background" Value="{StaticResource Success}"/>
    </Style>

    <!-- RedButton — ação destrutiva -->
    <Style x:Key="RedButton" TargetType="Button"
           BasedOn="{StaticResource AccentButton}">
        <Setter Property="Background" Value="{StaticResource Destructive}"/>
    </Style>

    <!-- ── RÓTULOS E RADIO ─────────────────────── -->

    <Style x:Key="Label" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Subtext0}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Margin"     Value="0,0,0,4"/>
    </Style>

    <Style x:Key="RadioStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Margin"     Value="0,0,16,0"/>
        <Setter Property="Cursor"     Value="Hand"/>
    </Style>

    <!-- ── LISTA (ListView) ────────────────────── -->

    <Style x:Key="DarkListViewItem" TargetType="ListViewItem">
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface0}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface1}"/>
                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── GRADE (DataGrid) ────────────────────── -->

    <Style x:Key="DarkDataGridHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="{StaticResource Surface0}"/>
        <Setter Property="Foreground"      Value="{StaticResource Accent}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="8,0"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Surface1}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="6,3"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface0}"/>
                <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
