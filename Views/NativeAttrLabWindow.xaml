
<Window x:Class="SetAtributesToolkit.NativeAttrLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SetAtributesToolkit"
        Title="Lab — Atributos Custom vs Nativos — Construct Sync"
        Width="1050" Height="720"
        MinWidth="860" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#FFFFFF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABEÇALHO -->
        <Border Grid.Row="0" Background="#1A237E" Padding="14,10">
            <StackPanel>
                <TextBlock Text="Lab — Atributos Custom vs Nativos"
                           Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="Teste o comportamento de atributos custom com o mesmo nome de categorias nativas"
                           Foreground="#9FA8DA" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- CORPO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PAINEL ESQUERDO: atributos nativos -->
            <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#D1D1D1" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="12,10,12,6">
                        <TextBlock Text="Atributos Nativos" Foreground="#2E2E2E"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="NativeSubtitle" Text="(carregando...)"
                                   Foreground="#9E9E9E" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <TreeView x:Name="NativeTree" Grid.Row="1"
                              Background="#F5F5F5" BorderThickness="0" Padding="6"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="False"/>
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type local:LabCatNode}" ItemsSource="{Binding Properties}">
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="#1A237E" CornerRadius="2" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="CAT" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               Foreground="#2E2E2E" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type local:LabPropNode}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="{Binding Name}" Foreground="#424242"
                                               FontSize="11" VerticalAlignment="Center" MinWidth="100"/>
                                    <TextBlock Text=" = " Foreground="#9E9E9E" FontSize="11"/>
                                    <TextBlock Text="{Binding Value}" Foreground="#1565C0"
                                               FontSize="11" VerticalAlignment="Center"
                                               MaxWidth="140" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Value}"/>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                    <Button x:Name="BtnReloadNative" Grid.Row="2"
                            Content="↺  Recarregar Seleção"
                            Background="#E8EAF6" Foreground="#1A237E" BorderThickness="0"
                            Padding="10,6" Margin="10,6,10,10"
                            HorizontalAlignment="Stretch"
                            Click="BtnReloadNative_Click"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#E8E8E8"/>

            <!-- PAINEL DIREITO: configuração + resultado -->
            <Grid Grid.Column="2" Margin="14,10,14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <!-- SEÇÃO 1: importar de categoria nativa -->
                <Border Grid.Row="0" Background="#E8EAF6" CornerRadius="4"
                        BorderBrush="#9FA8DA" BorderThickness="1" Padding="12,10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                   Text="1 — Importar propriedades de uma categoria nativa"
                                   FontWeight="SemiBold" Foreground="#1A237E" Margin="0,0,0,8"/>

                        <ComboBox x:Name="NativeCategoryCombo" Grid.Row="1" Grid.Column="0"
                                  Padding="8,5" Margin="0,0,8,0"
                                  Background="#FFFFFF" BorderBrush="#9FA8DA"/>

                        <Button x:Name="BtnImportNative" Grid.Row="1" Grid.Column="1"
                                Content="Importar →"
                                Background="#1A237E" Foreground="White" BorderThickness="0"
                                Padding="12,5"
                                Click="BtnImportNative_Click"/>
                    </Grid>
                </Border>

                <!-- SEÇÃO 2: nome da categoria custom -->
                <Border Grid.Row="1" Background="#FFF9C4" CornerRadius="4"
                        BorderBrush="#F9A825" BorderThickness="1" Padding="12,10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="2 — Nome da categoria custom a gravar"
                                   FontWeight="SemiBold" Foreground="#E65100" Margin="0,0,0,8"/>

                        <TextBox x:Name="CustomCategoryNameBox" Grid.Row="1"
                                 Background="#FFFFFF" Foreground="#2E2E2E"
                                 BorderBrush="#F9A825" BorderThickness="1"
                                 Padding="8,5" FontSize="13"
                                 GotFocus="EditingTextBox_GotFocus"/>

                        <TextBlock Grid.Row="2" Margin="0,5,0,0" FontSize="11" Foreground="#6D4C41"
                                   TextWrapping="Wrap">
                            <Run FontWeight="SemiBold">Dica do teste:</Run>
                            <Run>deixe igual a uma categoria nativa para ver se há coexistência ou sobreposição. Mude o nome para criar uma categoria completamente separada.</Run>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- SEÇÃO 3: grade de atributos -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="3 — Atributos a gravar"
                               FontWeight="SemiBold" Foreground="#2E2E2E" Margin="0,0,0,6"/>

                    <DataGrid x:Name="LabGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="False" SelectionUnit="CellOrRowHeader"
                              PreparingCellForEdit="LabGrid_PreparingCellForEdit"
                              Background="#FAFAFA" Foreground="#2E2E2E"
                              BorderBrush="#D1D1D1" BorderThickness="1"
                              RowBackground="#FAFAFA" AlternatingRowBackground="#FFFFFF"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E8E8E8"
                              HeadersVisibility="Column" ColumnHeaderHeight="28">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome do Atributo" Width="*"
                                                Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="Valor" Width="*"
                                                Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTemplateColumn Header="Tipo" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Type, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  SelectedValuePath="Content"
                                                  BorderThickness="0" Background="Transparent" Padding="4,2">
                                            <ComboBoxItem>string</ComboBoxItem>
                                            <ComboBoxItem>int</ComboBoxItem>
                                            <ComboBoxItem>double</ComboBoxItem>
                                            <ComboBoxItem>boolean</ComboBoxItem>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="" Width="34">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕"
                                                Background="#D32F2F" Foreground="White" BorderThickness="0"
                                                Width="24" Height="20" FontSize="9" Padding="0"
                                                Tag="{Binding}" Click="BtnRemoveLabRow_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button x:Name="BtnAddLabRow" Grid.Row="2"
                            Content="+ Adicionar Linha"
                            Background="#546E7A" Foreground="White" BorderThickness="0"
                            Padding="10,5" HorizontalAlignment="Left" Margin="0,6,0,0"
                            Click="BtnAddLabRow_Click"/>
                </Grid>

                <!-- BOTÃO ESCREVER -->
                <Button x:Name="BtnWriteAndVerify" Grid.Row="3"
                        Content="4 — Escrever e Verificar Resultado"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" HorizontalAlignment="Stretch"
                        Margin="0,10,0,0"
                        Click="BtnWriteAndVerify_Click"/>

                <!-- SEÇÃO 5: log de resultado -->
                <Border Grid.Row="4" Background="#F1F8E9" CornerRadius="4"
                        BorderBrush="#AED581" BorderThickness="1" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    Background="#DCEDC8" Margin="0,0,0,0" >
                            <TextBlock Text="5 — Log de Verificação"
                                       FontWeight="SemiBold" Foreground="#33691E"
                                       Padding="10,6"/>
                            <Button x:Name="BtnClearLog"
                                    Content="Limpar"
                                    Background="Transparent" Foreground="#558B2F"
                                    BorderThickness="0" Padding="6,4" Margin="4,0,0,0"
                                    FontSize="11" VerticalAlignment="Center"
                                    Click="BtnClearLog_Click"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,6">
                            <TextBlock x:Name="LogText"
                                       Foreground="#2E2E2E" FontFamily="Consolas" FontSize="11"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- RODAPÉ: status da seleção -->
        <Border Grid.Row="2" Background="#ECEFF1" BorderBrush="#CFD8DC"
                BorderThickness="0,1,0,0" Padding="14,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="FooterStatus" Foreground="#546E7A" FontSize="11"
                           Text="Aguardando seleção no modelo..."/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
