
<Window x:Class="SetAtributesToolkit.NativeAttrLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SetAtributesToolkit"
        Title="Write Properties"
        Width="1200" Height="720"
        MinWidth="900" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#FFFFFF">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SetAtributesToolkit;component/Themes/DesignSystem.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SetListItem" TargetType="ListViewItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderThickness="0" Padding="0">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Árvore nativa: categoria com badge CAT -->
            <HierarchicalDataTemplate DataType="{x:Type local:CatNode}" ItemsSource="{Binding Properties}">
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Border Background="#37474F" CornerRadius="2" Padding="3,1" Margin="0,0,5,0">
                        <TextBlock Text="CAT" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                               Foreground="#2E2E2E" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </HierarchicalDataTemplate>

            <!-- Árvore nativa: propriedade com checkbox -->
            <DataTemplate DataType="{x:Type local:PropNode}">
                <StackPanel Orientation="Horizontal" Margin="0,1">
                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                              VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding Name}" Foreground="#424242"
                               FontSize="11" VerticalAlignment="Center" MinWidth="80"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text=" = " Foreground="#9E9E9E" FontSize="11"/>
                    <TextBlock Text="{Binding CurrentValue}" Foreground="#1565C0"
                               FontSize="11" VerticalAlignment="Center"
                               MaxWidth="100" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding CurrentValue}"/>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ CABEÇALHO ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#263238" Padding="16,10">
            <StackPanel>
                <TextBlock Text="Write Properties"
                           Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock x:Name="HeaderSubtitle"
                           Text="Carregando..."
                           Foreground="#90A4AE" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ══ CORPO ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Col 0: atributos nativos com checkboxes -->
                <ColumnDefinition Width="230" MinWidth="160" MaxWidth="320"/>
                <ColumnDefinition Width="4"/>
                <!-- Col 2: storage category + sets -->
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="380"/>
                <ColumnDefinition Width="1"/>
                <!-- Col 4: modo + custom attributes + log -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── COL 0: ATRIBUTOS NATIVOS (interativos) ──────────────────── -->
            <Grid Grid.Column="0" Background="#F5F5F5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,10,12,8"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Native Attributes"
                                   FontWeight="SemiBold" FontSize="12" Foreground="#2E2E2E"/>
                        <TextBlock x:Name="NativeSubtitle"
                                   Text="(nenhuma seleção)"
                                   Foreground="#9E9E9E" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Árvore interativa com checkboxes -->
                <TreeView x:Name="NativeTree" Grid.Row="1"
                          Background="#F5F5F5" BorderThickness="0"
                          Padding="4" FontSize="11"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="Padding" Value="1"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <StackPanel Grid.Row="2" Margin="8,4,8,8">
                    <Button x:Name="BtnReloadNative"
                            Content="↺  Reload Selection"
                            Style="{StaticResource GhostButton}"
                            Padding="8,5" FontSize="11"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Click="BtnReloadNative_Click"/>
                    <Button x:Name="BtnClearChecks"
                            Content="Clear Checks"
                            Style="{StaticResource GhostButton}"
                            Padding="8,5" FontSize="11"
                            HorizontalAlignment="Stretch"
                            Click="BtnClearChecks_Click"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <!-- ── COL 2: STORAGE CATEGORY + SETS ──────────────────────────── -->
            <Grid Grid.Column="2" Background="#FAFAFA">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Storage Category -->
                <Border Grid.Row="0" Padding="14,12,14,10"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Storage Category"
                                   FontWeight="SemiBold" FontSize="12" Foreground="#2E2E2E"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="All created attributes are stored under this fixed category"
                                   Foreground="#757575" FontSize="10"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="StorageCategoryBox"
                                     Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}"
                                     Margin="0,0,6,0"
                                     GotFocus="TextBox_GotFocus"/>
                            <Button x:Name="BtnResetCategory"
                                    Grid.Column="1"
                                    Content="Reset"
                                    Style="{StaticResource GhostButton}"
                                    Padding="10,4" FontSize="11"
                                    Click="BtnResetCategory_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Detected Sets — título -->
                <Border Grid.Row="1" Padding="14,10,14,6"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Detected Sets"
                                   FontWeight="SemiBold" FontSize="12" Foreground="#2E2E2E"
                                   Margin="0,0,0,2"/>
                        <TextBlock x:Name="SetsCountText"
                                   Foreground="#1565C0" FontSize="10"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Clear / Select All + contagem -->
                <Grid Grid.Row="2" Margin="14,6,14,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SelectedCountText"
                               Grid.Column="0"
                               Text="0 selected"
                               Foreground="#757575" FontSize="10"
                               VerticalAlignment="Center"/>
                    <Button x:Name="BtnClearSets"
                            Grid.Column="1"
                            Content="Clear"
                            Style="{StaticResource NavButton}"
                            Margin="0,0,4,0"
                            Click="BtnClearSets_Click"/>
                    <Button x:Name="BtnSelectAllSets"
                            Grid.Column="2"
                            Content="Select All"
                            Style="{StaticResource NavButton}"
                            Click="BtnSelectAllSets_Click"/>
                </Grid>

                <!-- Busca -->
                <TextBox x:Name="SetsSearchBox"
                         Grid.Row="3"
                         Style="{StaticResource DarkTextBox}"
                         Tag="Search sets..."
                         Margin="14,0,14,4"
                         TextChanged="SetsSearchBox_TextChanged"/>

                <!-- Lista de sets -->
                <ListView x:Name="SetsListView"
                          Grid.Row="4"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ItemContainerStyle="{StaticResource SetListItem}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,4" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="11" Foreground="#2E2E2E"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Column="2"
                                            Background="#E3F2FD" CornerRadius="8"
                                            Padding="5,1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ItemCount}"
                                                   FontSize="9" Foreground="#1565C0"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Divisor vertical -->
            <Border Grid.Column="3" Background="#E0E0E0"/>

            <!-- ── COL 4: MODO + CUSTOM ATTRIBUTES + LOG ───────────────────── -->
            <Grid Grid.Column="4" Margin="16,12,16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>           <!-- Row 0: Mode selector -->
                    <RowDefinition Height="Auto"/>           <!-- Row 1: Mode header -->
                    <RowDefinition Height="Auto"/>           <!-- Row 2: Título -->
                    <RowDefinition Height="Auto"/>           <!-- Row 3: Category box -->
                    <RowDefinition Height="Auto"/>           <!-- Row 4: Hint -->
                    <RowDefinition Height="2*"/>             <!-- Row 5: Grade -->
                    <RowDefinition Height="Auto"/>           <!-- Row 6: Write & Verify button -->
                    <RowDefinition Height="Auto"/>           <!-- Row 7: Status panel -->
                    <RowDefinition Height="*" MinHeight="110"/> <!-- Row 8: Log -->
                </Grid.RowDefinitions>

                <!-- Row 0: Seletor de modo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Mode:" Foreground="#5A5A5A" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <RadioButton x:Name="RadioGravar" Content="Write" GroupName="ModoOp"
                                 IsChecked="True" Checked="RadioModo_Changed"
                                 Foreground="#2E2E2E" Margin="0,0,14,0" FontSize="11"/>
                    <RadioButton x:Name="RadioEditar" Content="Edit" GroupName="ModoOp"
                                 Checked="RadioModo_Changed"
                                 Foreground="#2E2E2E" Margin="0,0,14,0" FontSize="11"/>
                    <RadioButton x:Name="RadioExcluir" Content="Delete" GroupName="ModoOp"
                                 Checked="RadioModo_Changed"
                                 Foreground="#2E2E2E" FontSize="11"/>
                </StackPanel>

                <!-- Row 1: Header de modo (cor dinâmica) -->
                <Border x:Name="ModeHeaderBorder" Grid.Row="1"
                        CornerRadius="3" Padding="8,5" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ModeHeaderIcon" Text="●" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="ModeHeaderText" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Row 2: Título da seção -->
                <TextBlock x:Name="SectionTitle" Grid.Row="2"
                           Text="Custom Attributes"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="#2E2E2E" Margin="0,0,0,10"/>

                <!-- Row 3: Category field -->
                <Grid Grid.Row="3" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,6,0">
                        <TextBlock Text="Category:" FontSize="11" Foreground="#5A5A5A"/>
                        <TextBlock x:Name="NewCategoryLabel" Text=" (new)" Foreground="#FC6A0A"
                                   FontSize="10" FontStyle="Italic" Visibility="Collapsed"/>
                        <TextBlock x:Name="ExistingCategoryLabel" Text=" (existing)" Foreground="#2E7D32"
                                   FontSize="10" FontStyle="Italic" Visibility="Collapsed"/>
                    </StackPanel>
                    <TextBox x:Name="CustomCategoryBox"
                             Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             GotFocus="TextBox_GotFocus"/>
                </Grid>

                <!-- Row 4: Hint -->
                <TextBlock Grid.Row="4"
                           FontSize="10" Foreground="#9E9E9E"
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Text="Check props in the tree to populate the grid. Set names are stored in the AWP field via Storage Category."/>

                <!-- Row 5: Grade de atributos -->
                <Grid Grid.Row="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <Button x:Name="BtnAddRow"
                                Content="+ Add Row"
                                Style="{StaticResource GhostButton}"
                                Background="#E3F2FD" Foreground="#1565C0"
                                Padding="8,4" Margin="0,0,4,3" FontSize="11"
                                Click="BtnAddRow_Click"/>
                        <Button x:Name="BtnRemoveRow"
                                Content="- Remove"
                                Style="{StaticResource GhostButton}"
                                Background="#FFEBEE" Foreground="#C62828"
                                Padding="8,4" Margin="0,0,4,3" FontSize="11"
                                Click="BtnRemoveSelectedRow_Click"/>
                        <Button x:Name="BtnClearGrid"
                                Content="Clear Grid"
                                Style="{StaticResource GhostButton}"
                                Padding="8,4" Margin="0,0,4,3" FontSize="11"
                                Click="BtnClearGrid_Click"/>
                        <Button x:Name="BtnNewCategory"
                                Content="New Category"
                                Style="{StaticResource GhostButton}"
                                Background="#FFF3E0" Foreground="#E65100"
                                Padding="8,4" Margin="0,0,4,3" FontSize="11"
                                Click="BtnNewCategory_Click"/>
                        <Button x:Name="BtnExport"
                                Content="Export"
                                Style="{StaticResource GhostButton}"
                                Padding="8,4" Margin="0,0,4,3" FontSize="11"
                                Click="BtnExport_Click"/>
                        <Button x:Name="BtnImport"
                                Content="Import"
                                Style="{StaticResource GhostButton}"
                                Padding="8,4" Margin="0,0,0,3" FontSize="11"
                                Click="BtnImport_Click"/>
                    </WrapPanel>

                    <DataGrid x:Name="AttributesGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              SelectionUnit="FullRow"
                              SelectionMode="Extended"
                              PreparingCellForEdit="AttributesGrid_PreparingCellForEdit"
                              Background="#FFFFFF" Foreground="#2E2E2E"
                              BorderBrush="#D1D1D1" BorderThickness="1"
                              RowBackground="#FFFFFF" AlternatingRowBackground="#FAFAFA"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                              HeadersVisibility="Column" ColumnHeaderHeight="30"
                              ColumnHeaderStyle="{StaticResource DarkDataGridHeader}"
                              CellStyle="{StaticResource DarkDataGridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Width="*"
                                               Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="Value" Width="*"
                                               Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTemplateColumn Header="Type" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Type}"
                                                   Padding="8,4" VerticalAlignment="Center"
                                                   Foreground="#2E2E2E"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Content"
                                                  BorderThickness="0" Background="Transparent" Padding="4,2">
                                            <ComboBoxItem>string</ComboBoxItem>
                                            <ComboBoxItem>int</ComboBoxItem>
                                            <ComboBoxItem>double</ComboBoxItem>
                                            <ComboBoxItem>boolean</ComboBoxItem>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Row 6: Botão Write & Verify / Delete -->
                <Button x:Name="BtnWriteAndVerify"
                        Grid.Row="6"
                        Content="Write &amp; Verify (selection)"
                        Style="{StaticResource GhostButton}"
                        Background="#E8F5E9" Foreground="#2E7D32"
                        FontSize="11" Padding="10,5"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,0"
                        Click="BtnWriteAndVerify_Click"/>

                <!-- Row 7: Status panel -->
                <Border x:Name="ContextPanel" Grid.Row="7"
                        CornerRadius="3" Padding="8,6" Margin="0,6,0,0"
                        Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="StatusText"
                                   Foreground="#5A5A5A" FontSize="11"/>
                        <Border x:Name="ZeroSelectionWarning"
                                Background="#FFF3E0" CornerRadius="3"
                                Padding="8,5" Margin="0,4,0,0"
                                Visibility="Collapsed">
                            <TextBlock Text="⚠  No elements selected in the model"
                                       Foreground="#E65100" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Row 8: Log -->
                <Border Grid.Row="8" Background="#F1F8E9"
                        BorderBrush="#AED581" BorderThickness="1"
                        Margin="0,8,0,0" CornerRadius="3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Background="#DCEDC8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Verification Log"
                                       FontWeight="SemiBold" Foreground="#33691E"
                                       FontSize="11" Padding="8,5"/>
                            <Button x:Name="BtnClearLog"
                                    Grid.Column="1"
                                    Content="Clear"
                                    Background="Transparent" Foreground="#558B2F"
                                    BorderThickness="0" Padding="6,4" FontSize="10"
                                    VerticalAlignment="Center"
                                    Click="BtnClearLog_Click"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="8,4">
                            <TextBlock x:Name="LogText"
                                       Foreground="#2E2E2E" FontFamily="Consolas"
                                       FontSize="10" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ══ RODAPÉ ═════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#F5F5F5"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatus"
                           Grid.Column="0"
                           Foreground="#757575" FontSize="11"
                           VerticalAlignment="Center"
                           Text="Aguardando..."/>
                <Button x:Name="BtnCancel"
                        Grid.Column="1"
                        Content="Cancel"
                        Style="{StaticResource GhostButton}"
                        Padding="18,6" Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>
                <Button x:Name="BtnDelete"
                        Grid.Column="2"
                        Content="Delete (Sets)"
                        Style="{StaticResource RedButton}"
                        Padding="18,6" Margin="0,0,8,0"
                        Click="BtnDelete_Click"/>
                <Button x:Name="BtnSave"
                        Grid.Column="3"
                        Content="Save (Sets)"
                        Style="{StaticResource AccentButton}"
                        Background="#1565C0"
                        Padding="26,6"
                        Click="BtnSave_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
