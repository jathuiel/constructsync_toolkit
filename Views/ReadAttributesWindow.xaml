<!--
    ReadAttributesWindow.xaml — Construct Sync Toolkit
    Janela de leitura de atributos BIM dos elementos selecionados no Navisworks.

    Estilos e paleta: Themes/DesignSystem.xaml (fonte única de verdade)

    Layout (Grid de 3 linhas):
      Row 0 — Cabeçalho: título + barra de navegação (◄◄ ◄ N/T ► ►►) + status
      Row 1 — Painel duplo: Categorias (esquerda) | Propriedades (direita) — elástico
      Row 2 — Rodapé: Atualizar | Fechar | Copiar
-->
<Window x:Class="TestePlugin.ReadAttributesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ler Atributos — Construct Sync"
        Width="860" Height="580"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#292929">

    <!-- Carrega o design system — remove duplicação de estilos entre janelas -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TestePlugin;component/Themes/DesignSystem.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Cabeçalho -->
            <RowDefinition Height="*"/>      <!-- Painéis de dados -->
            <RowDefinition Height="Auto"/>   <!-- Rodapé / botões -->
        </Grid.RowDefinitions>

        <!-- ── CABEÇALHO ─────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Título -->
                <RowDefinition Height="Auto"/>  <!-- Barra de navegação -->
                <RowDefinition Height="Auto"/>  <!-- Status -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Ler Atributos"
                       Foreground="{StaticResource Text}"
                       FontSize="15" FontWeight="SemiBold"/>

            <!-- Barra de navegação entre elementos selecionados.
                 Só aparece quando há mais de 1 elemento (controlada pelo code-behind). -->
            <StackPanel x:Name="NavPanel" Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,6,0,0"
                        Visibility="Collapsed">

                <Button x:Name="BtnFirst" Content="◄◄"
                        Style="{StaticResource NavButton}"
                        Margin="0,0,2,0"
                        Click="BtnFirst_Click"
                        ToolTip="Primeiro elemento"/>
                <Button x:Name="BtnPrev" Content="◄"
                        Style="{StaticResource NavButton}"
                        Margin="0,0,4,0"
                        Click="BtnPrev_Click"
                        ToolTip="Elemento anterior"/>

                <!-- Contador: ex. "2 / 13" -->
                <Border Background="{StaticResource Surface0}" CornerRadius="4"
                        Padding="10,3" Margin="0,0,4,0">
                    <TextBlock x:Name="NavText"
                               Foreground="{StaticResource Text}" FontSize="11"
                               MinWidth="48" TextAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <Button x:Name="BtnNext" Content="►"
                        Style="{StaticResource NavButton}"
                        Margin="0,0,2,0"
                        Click="BtnNext_Click"
                        ToolTip="Próximo elemento"/>
                <Button x:Name="BtnLast" Content="►►"
                        Style="{StaticResource NavButton}"
                        Click="BtnLast_Click"
                        ToolTip="Último elemento"/>
            </StackPanel>

            <!-- StatusText: nome do elemento + contagens de categorias e propriedades -->
            <TextBlock x:Name="StatusText" Grid.Row="2"
                       Foreground="{StaticResource Subtext0}"
                       FontSize="11" Margin="0,4,0,0"/>
        </Grid>

        <!-- ── CORPO: PAINEL DUPLO ────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="160"/>  <!-- Categorias -->
                <ColumnDefinition Width="6"/>                   <!-- Splitter -->
                <ColumnDefinition Width="*"   MinWidth="200"/>  <!-- Propriedades -->
            </Grid.ColumnDefinitions>

            <!-- ┌─────────────────────────────────────────┐
                 │  PAINEL ESQUERDO — Categorias           │
                 │  Label > SearchBox > ListView           │
                 └─────────────────────────────────────────┘ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Categorias"
                           Foreground="{StaticResource Text}" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <!-- Tag define o placeholder do ControlTemplate -->
                <TextBox x:Name="CatSearchBox" Grid.Row="1"
                         Style="{StaticResource DarkTextBox}"
                         Tag="Filtrar categorias…"
                         Margin="0,0,0,6"
                         GotFocus="SearchBox_GotFocus"
                         TextChanged="CatSearch_TextChanged"/>

                <Border Grid.Row="2"
                        Background="{StaticResource Mantle}"
                        BorderBrush="{StaticResource Surface1}" BorderThickness="1" CornerRadius="4">
                    <ListView x:Name="CategoriesListView"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="{StaticResource Text}"
                              ItemContainerStyle="{StaticResource DarkListViewItem}"
                              SelectionChanged="CategoriesListView_SelectionChanged">

                        <!-- Template: Nome da categoria | Contagem (alinhada à direita) -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Count}"
                                               Foreground="{StaticResource Overlay1}"
                                               FontSize="11"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>

            <!-- ── DIVISOR REDIMENSIONÁVEL ────────────────────────── -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource Surface1}"
                          ShowsPreview="False"/>

            <!-- ┌─────────────────────────────────────────┐
                 │  PAINEL DIREITO — Propriedades          │
                 │  Título dinâmico > SearchBox > DataGrid │
                 └─────────────────────────────────────────┘ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Atualizado pelo code-behind com o nome da categoria selecionada -->
                <TextBlock x:Name="PropPanelTitle" Grid.Row="0"
                           Text="Selecione uma categoria"
                           Foreground="{StaticResource Text}" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="PropSearchBox" Grid.Row="1"
                         Style="{StaticResource DarkTextBox}"
                         Tag="Filtrar propriedades…"
                         Margin="0,0,0,6"
                         GotFocus="SearchBox_GotFocus"
                         TextChanged="PropSearch_TextChanged"/>

                <!-- Grade: somente leitura, múltipla seleção por linha completa -->
                <DataGrid x:Name="PropertiesGrid" Grid.Row="2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          Background="{StaticResource Mantle}"
                          Foreground="{StaticResource Text}"
                          BorderBrush="{StaticResource Surface1}"
                          BorderThickness="1"
                          RowBackground="{StaticResource Mantle}"
                          AlternatingRowBackground="{StaticResource Base}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource Surface0}"
                          HeadersVisibility="Column"
                          ColumnHeaderHeight="30"
                          ColumnHeaderStyle="{StaticResource DarkDataGridHeader}"
                          CellStyle="{StaticResource DarkDataGridCell}">

                    <!-- Propriedade e Valor flexíveis; Tipo fixo em 120px -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Propriedade"
                                            Binding="{Binding Property}" Width="*"/>
                        <DataGridTextColumn Header="Valor"
                                            Binding="{Binding Value}"    Width="*"/>
                        <DataGridTextColumn Header="Tipo"
                                            Binding="{Binding Type}"     Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ── RODAPÉ — Ações ────────────────────────────────────── -->
        <!--
            Atualizar — recarrega a seleção atual
            Fechar    — fecha a janela
            Copiar    — linhas selecionadas (ou todas) → clipboard TSV
        -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Atualizar"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,6,0"
                    Click="BtnRefresh_Click"/>
            <Button Content="Fechar"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,6,0"
                    Click="BtnClose_Click"/>
            <Button Content="Copiar"
                    Style="{StaticResource AccentButton}"
                    Click="BtnCopy_Click"/>
        </StackPanel>
    </Grid>
</Window>
