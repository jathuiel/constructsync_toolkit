<Window x:Class="SetAtributesToolkit.WriteAttributesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SetAtributesToolkit"
        Title="Gravar Atributos — Construct Sync"
        Width="900" Height="680"
        MinWidth="800" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#FFFFFF">

    <Window.Resources>
        <Style x:Key="ModeHeaderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <HierarchicalDataTemplate x:Key="CatNodeTemplate" DataType="{x:Type local:CatNode}" ItemsSource="{Binding Properties}">
            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#2E2E2E" Margin="2,4"/>
        </HierarchicalDataTemplate>

        <DataTemplate x:Key="PropNodeTemplate" DataType="{x:Type local:PropNode}">
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" Foreground="#2E2E2E" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentValue, StringFormat=' ({0})'}" Foreground="#9E9E9E" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#D1D1D1" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Attribute Sets"
                           Foreground="#2E2E2E" FontSize="13" FontWeight="SemiBold"
                           Padding="12,12,12,8"/>

                <TreeView x:Name="SetsTreeView" Grid.Row="1"
                          Background="#F5F5F5" Foreground="#2E2E2E"
                          BorderThickness="0" Padding="4"
                          ItemTemplate="{StaticResource CatNodeTemplate}">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <DataTemplate DataType="{x:Type local:PropNode}">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Name}" Foreground="#2E2E2E" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentValue, StringFormat=' ({0})'}" Foreground="#9E9E9E" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </TreeView.Resources>
                </TreeView>

                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="8,8">
                    <Button Content="+ Nova Categoria" HorizontalAlignment="Stretch"
                            FontSize="11" Padding="6,4" Margin="0,0,0,4"
                            Background="#FC6A0A" Foreground="White" BorderThickness="0"
                            Click="BtnNewSet_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DIVISOR -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#E8E8E8"/>

        <!-- CONTEÚDO PRINCIPAL -->
        <Grid Grid.Column="2" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- MODO -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Modo:" Foreground="#5A5A5A" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <RadioButton x:Name="RadioGravar" Content="Gravar Novo" GroupName="ModoOperacao"
                             Foreground="#2E2E2E" Margin="0,0,16,0"
                             IsChecked="True" Checked="RadioModo_Changed"/>
                <RadioButton x:Name="RadioEditar" Content="Editar Existente" GroupName="ModoOperacao"
                             Foreground="#2E2E2E" Margin="0,0,16,0"
                             Checked="RadioModo_Changed"/>
                <RadioButton x:Name="RadioExcluir" Content="Excluir" GroupName="ModoOperacao"
                             Foreground="#2E2E2E" Margin="0,0,16,0"
                             Checked="RadioModo_Changed"/>
            </StackPanel>

            <!-- HEADER DE ESTADO DO MODO -->
            <Border x:Name="ModeHeaderBorder" Grid.Row="1" Style="{StaticResource ModeHeaderStyle}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ModeHeaderIcon" Text="●" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="ModeHeaderText" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>


            <!-- TÍTULO -->
            <TextBlock x:Name="SectionTitle" Grid.Row="3" Text="Atributos a Gravar"
                       Foreground="#2E2E2E" FontSize="14" FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <!-- CATEGORIA -->
            <StackPanel x:Name="CategoryPanel" Grid.Row="4" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Nome da Categoria:" Foreground="#5A5A5A" FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="NewCategoryLabel" Text=" (nova)" Foreground="#FC6A0A" FontSize="11"
                               FontStyle="Italic" VerticalAlignment="Center" Margin="4,0,0,0"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="ExistingCategoryLabel" Text=" (existente)" Foreground="#2E7D32" FontSize="11"
                               FontStyle="Italic" VerticalAlignment="Center" Margin="4,0,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
                <TextBox x:Name="CategoryNameBox"
                         Background="#FAFAFA" Foreground="#2E2E2E"
                         BorderBrush="#D1D1D1" BorderThickness="1"
                         Padding="8,5" Text=""
                         GotFocus="EditingTextBox_GotFocus"/>
            </StackPanel>

            <!-- GRADE -->
            <Grid Grid.Row="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Atributos:"
                           Foreground="#5A5A5A" FontSize="12" Margin="0,0,0,4"/>

                <DataGrid x:Name="AttributesGrid" Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="False" SelectionUnit="CellOrRowHeader"
                          BeginningEdit="AttributesGrid_BeginningEdit"
                          PreparingCellForEdit="AttributesGrid_PreparingCellForEdit"
                          Background="#F5F5F5" Foreground="#2E2E2E"
                          BorderBrush="#D1D1D1" BorderThickness="1"
                          RowBackground="#F5F5F5" AlternatingRowBackground="#FFFFFF"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E8E8E8"
                          HeadersVisibility="Column" ColumnHeaderHeight="28">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nome do Atributo" Width="*"
                                            Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="Valor" Width="*"
                                            Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTemplateColumn Header="Tipo" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedValue="{Binding Type, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                              SelectedValuePath="Content"
                                              BorderThickness="0" Background="Transparent"
                                              Padding="4,2">
                                        <ComboBoxItem>string</ComboBoxItem>
                                        <ComboBoxItem>int</ComboBoxItem>
                                        <ComboBoxItem>double</ComboBoxItem>
                                        <ComboBoxItem>boolean</ComboBoxItem>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn x:Name="RemoveColumn" Header="" Width="36">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="BtnRemove"
                                            Content="✕"
                                            Background="#D32F2F" Foreground="White" BorderThickness="0"
                                            Width="26" Height="22" FontSize="10" Padding="0"
                                            Tag="{Binding}" Click="BtnRemoveRow_Click"
                                            ToolTip="Remover atributo"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Button x:Name="BtnAddRow" Grid.Row="2" Content="+ Adicionar Atributo"
                        Background="#FC6A0A" Foreground="White" BorderThickness="0"
                        Padding="12,6" HorizontalAlignment="Left" Margin="0,6,0,0"
                        Click="BtnAddRow_Click"/>
            </Grid>

            <!-- PAINEL DE CONTEXTO (visível sempre) -->
            <Border x:Name="ContextPanel" Grid.Row="6"
                    CornerRadius="4" Padding="10,8" Margin="0,8,0,4">
                <StackPanel>
                    <TextBlock x:Name="ContextActionText" FontSize="11" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="StatusText" Foreground="#5A5A5A" FontSize="11"/>
                    <!-- Aviso zero elementos -->
                    <Border x:Name="ZeroSelectionWarning" Background="#FFF3E0" CornerRadius="3"
                            Padding="8,5" Margin="0,4,0,0" Visibility="Collapsed">
                        <TextBlock Text="⚠ Nenhum elemento selecionado no modelo"
                                   Foreground="#E65100" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- BOTÃO EXECUTAR -->
            <Button x:Name="BtnWrite" Grid.Row="7"
                    Content="Gravar nos Elementos Selecionados"
                    Background="#2E7D32" Foreground="White" BorderThickness="0"
                    Padding="12,8" HorizontalAlignment="Stretch"
                    Click="BtnWrite_Click"/>
        </Grid>
    </Grid>
</Window>
