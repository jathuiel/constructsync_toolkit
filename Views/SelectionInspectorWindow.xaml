<Window x:Class="SetAtributesToolkit.SelectionInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Construct Sync — Selection Inspector"
        Width="980" Height="640"
        MinWidth="700" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#FFFFFF">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SetAtributesToolkit;component/Themes/DesignSystem.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Cabeçalho duplo da coluna: Categoria / Propriedade -->
            <DataTemplate x:Key="ColHeaderTemplate">
                <StackPanel HorizontalAlignment="Left" Margin="0,2,0,2">
                    <TextBlock Text="{Binding Category}"
                               Foreground="{StaticResource Accent}"
                               FontWeight="SemiBold" FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Property}"
                               Foreground="{StaticResource Text}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </DataTemplate>

            <!-- Botão estilo link (Selecionar Tudo / Limpar) -->
            <Style x:Key="LinkButton" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground"      Value="{StaticResource Accent}"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Padding"         Value="0"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       TextDecorations="Underline"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource AccentHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Item da lista de categorias -->
            <Style x:Key="CatListItem" TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding"                    Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bg"
                                    Background="Transparent"
                                    Padding="10,5">
                                <CheckBox x:Name="Cb"
                                          Content="{Binding Name}"
                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          Foreground="{StaticResource Text}"
                                          FontSize="12"
                                          Cursor="Hand"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E8F0FE"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#2563EB"/>
                                    <Setter TargetName="Cb" Property="Foreground"  Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header escuro -->
            <RowDefinition Height="*"/>     <!-- Conteúdo -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════
             HEADER ESCURO
             ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1E2B3C" Padding="18,14,18,14">
            <StackPanel>
                <TextBlock Text="Selection Inspector"
                           Foreground="White"
                           FontSize="20" FontWeight="Bold"
                           Margin="0,0,0,3"/>
                <TextBlock x:Name="TxtSubtitle"
                           Text="Selecione elementos no modelo para começar."
                           Foreground="#8090A0"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════
             CONTEÚDO: Painel Esquerdo + DataGrid
             ══════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="180"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── PAINEL ESQUERDO: Categorias ────────────── -->
            <Grid Grid.Column="0" Background="#FFFFFF">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Título "Categorias" -->
                <Border Grid.Row="0"
                        Background="{StaticResource Mantle}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <TextBlock Text="Categorias"
                               Foreground="{StaticResource Text}"
                               FontSize="12" FontWeight="SemiBold"/>
                </Border>

                <!-- Selecionar Tudo | Limpar -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="10,6,10,4">
                    <Button Content="Selecionar Tudo"
                            Style="{StaticResource LinkButton}"
                            Click="BtnSelectAll_Click"/>
                    <TextBlock Text=" | "
                               Foreground="{StaticResource Overlay1}"
                               VerticalAlignment="Center"
                               Margin="4,0"/>
                    <Button Content="Limpar"
                            Style="{StaticResource LinkButton}"
                            Click="BtnClearAll_Click"/>
                </StackPanel>

                <!-- Lista de categorias com CheckBox -->
                <ListBox x:Name="CategoriesList"
                         Grid.Row="2"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource CatListItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionMode="Single"/>
            </Grid>

            <!-- Separador vertical -->
            <Rectangle Grid.Column="1"
                       Fill="{StaticResource Border}"
                       Width="1"/>

            <!-- ─── DATAGRID DINÂMICO ────────────────────── -->
            <DataGrid x:Name="InspectorGrid"
                      Grid.Column="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="{StaticResource Mantle}"
                      BorderThickness="0"
                      RowBackground="#FFFFFF"
                      AlternatingRowBackground="{StaticResource Mantle}"
                      ColumnHeaderStyle="{StaticResource DarkDataGridHeader}"
                      CellStyle="{StaticResource DarkDataGridCell}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      EnableRowVirtualization="True"
                      Margin="0">

                <!-- Mensagem quando grid vazio -->
                <DataGrid.Style>
                    <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                    </Style>
                </DataGrid.Style>
            </DataGrid>

            <!-- Placeholder quando nenhuma categoria selecionada -->
            <TextBlock x:Name="TxtEmptyHint"
                       Grid.Column="2"
                       Text="Marque categorias à esquerda para visualizar as propriedades."
                       Foreground="{StaticResource Overlay1}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Visibility="Visible"/>
        </Grid>

        <!-- ══════════════════════════════════════════════
             FOOTER: Status + Botões
             ══════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource Mantle}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Ellipse x:Name="StatusIndicator"
                         Grid.Column="0"
                         Width="8" Height="8"
                         Fill="{StaticResource Info}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBlock x:Name="TxtStatus"
                           Grid.Column="1"
                           Text="—"
                           Foreground="{StaticResource Overlay1}"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <!-- Export CSV -->
                <Button x:Name="BtnExportCsv"
                        Grid.Column="3"
                        Content="Export"
                        Style="{StaticResource GreenButton}"
                        Width="76"
                        ToolTip="Exportar como CSV"
                        Click="BtnExportCsv_Click"
                        IsEnabled="False"/>

                <!-- Copy to Clipboard -->
                <Button x:Name="BtnExportClip"
                        Grid.Column="5"
                        Content="Copiar Dados"
                        Style="{StaticResource AccentButton}"
                        Width="76"
                        ToolTip="Copiar para Área de Transferência (TSV)"
                        Click="BtnExportClip_Click"
                        IsEnabled="False"/>

                <Button Grid.Column="7"
                        Content="Fechar"
                        Style="{StaticResource GhostButton}"
                        Width="76"
                        Click="BtnClose_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
