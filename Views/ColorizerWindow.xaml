<!--
    ColorizerWindow.xaml — Construct Sync Toolkit
    Janela de colorização de sets por Selection Sets, Search Sets ou modelo inteiro.

    Estilos e paleta: Themes/DesignSystem.xaml (fonte única de verdade)

    Layout (Grid de 6 linhas):
      Row 0 — Título
      Row 1 — Radio buttons de fonte (Selection | Search | Todos)
      Row 2 — Botões de cor em lote (Aleatória | Paleta | Restaurar)
      Row 3 — ListView de sets com swatch clicável (elástica)
      Row 4 — StatusText
      Row 5 — Botão "Aplicar Cores nos Sets Selecionados"
-->
<Window x:Class="TestePlugin.ColorizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codificação Visual — Construct Sync"
        Width="520" Height="560"
        MinWidth="420" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#292929">

    <!-- Carrega o design system — remove duplicação de estilos entre janelas -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TestePlugin;component/Themes/DesignSystem.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Título -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: Fonte dos sets -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: Botões de cor em lote -->
            <RowDefinition Height="*"/>     <!-- Row 3: Lista de sets (elástica) -->
            <RowDefinition Height="Auto"/>  <!-- Row 4: Status -->
            <RowDefinition Height="Auto"/>  <!-- Row 5: Botão aplicar -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: TÍTULO ──────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="Codificação Visual"
                   Foreground="{StaticResource Text}"
                   FontSize="15" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- ── Row 1: FONTE DOS SETS ──────────────────────────────── -->
        <!--
            Três opções mutuamente exclusivas:
              • Selection Sets — seleção explícita
              • Search Sets    — baseados em critérios de busca
              • Todos          — todos os elementos dos modelos abertos
            Checked="RadioSource_Checked" recarrega a lista a cada mudança.
        -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Fonte:"
                       Foreground="{StaticResource Subtext0}"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <RadioButton x:Name="RadioSelectionSets"
                         Content="Selection Sets"
                         Style="{StaticResource RadioStyle}"
                         IsChecked="True"
                         Checked="RadioSource_Checked"/>
            <RadioButton x:Name="RadioSearchSets"
                         Content="Search Sets"
                         Style="{StaticResource RadioStyle}"
                         Checked="RadioSource_Checked"/>
            <RadioButton x:Name="RadioAllElements"
                         Content="Todos os Elementos"
                         Style="{StaticResource RadioStyle}"
                         Checked="RadioSource_Checked"/>
        </StackPanel>

        <!-- ── Row 2: BOTÕES DE COR EM LOTE ──────────────────────── -->
        <!--
            • Cor Aleatória      — RGB aleatório por set (60–239 por canal)
            • Paleta Predefinida — cicla paleta de 20 cores vibrantes
            • Restaurar Cores   — OverrideResetAll via COM API (vermelho = irreversível)
        -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Cor Aleatória"
                    Style="{StaticResource AccentButton}"
                    Margin="0,0,6,0"
                    Click="BtnRandomColor_Click"/>
            <Button Content="Paleta Predefinida"
                    Style="{StaticResource AccentButton}"
                    Margin="0,0,6,0"
                    Click="BtnApplyPalette_Click"/>
            <Button Content="Restaurar Cores"
                    Style="{StaticResource RedButton}"
                    Click="BtnRestore_Click"/>
        </StackPanel>

        <!-- ── Row 3: LISTA DE SETS ───────────────────────────────── -->
        <!--
            SelectionMode="Extended" → Ctrl/Shift para múltipla seleção.
            MouseDoubleClick         → seleciona elementos do set no modelo.
        -->
        <Border Grid.Row="3"
                Background="{StaticResource Mantle}"
                BorderBrush="{StaticResource Surface1}" BorderThickness="1"
                CornerRadius="4">
            <ListView x:Name="SetsListView"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="{StaticResource Text}"
                      SelectionMode="Extended"
                      MouseDoubleClick="SetsListView_DoubleClick">

                <!-- Herda DarkListViewItem; Padding reduzido para linha com swatch -->
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem"
                           BasedOn="{StaticResource DarkListViewItem}">
                        <Setter Property="Padding" Value="6,4"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <!-- Template: 3 colunas — Swatch (28px) | Nome (*) | Tipo (Auto) -->
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>   <!-- Swatch -->
                                <ColumnDefinition Width="*"/>    <!-- Nome -->
                                <ColumnDefinition Width="Auto"/> <!-- Tipo -->
                            </Grid.ColumnDefinitions>

                            <!-- Swatch clicável — MouseLeftButtonDown evita conflito com seleção do item -->
                            <Border Grid.Column="0"
                                    Width="20" Height="20"
                                    CornerRadius="3"
                                    Background="{Binding ColorBrush}"
                                    BorderBrush="{StaticResource Surface1}" BorderThickness="1"
                                    Cursor="Hand"
                                    Tag="{Binding}"
                                    MouseLeftButtonDown="Swatch_Click"
                                    ToolTip="Clique para escolher a cor deste set"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding SetName}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>

                            <!-- Tipo em texto menor e secundário para hierarquia visual -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding SetType}"
                                       Foreground="{StaticResource Overlay1}"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </Border>

        <!-- ── Row 4: STATUS ──────────────────────────────────────── -->
        <!-- Atualizado com: contagem de sets, resultado da aplicação, erros -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Foreground="{StaticResource Overlay1}"
                   FontSize="11"
                   Margin="0,6,0,4"/>

        <!-- ── Row 5: BOTÃO APLICAR ───────────────────────────────── -->
        <!-- Se nenhum set estiver selecionado na lista, aplica em todos -->
        <Button Grid.Row="5"
                Content="Aplicar Cores nos Sets Selecionados"
                Style="{StaticResource AccentButton}"
                HorizontalAlignment="Stretch"
                Click="BtnApplySelected_Click"/>

    </Grid>
</Window>
